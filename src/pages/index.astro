---
import BaseLayout from "../layouts/BaseLayout.astro";
import Homeslider from "../components/Homeslider.astro";
import Plans from "../components/Plans.astro";
import { fetchAPI } from "../lib/wordpress";
import { Image } from "astro:assets";

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=120, stale-while-revalidate=30'
);

const Homequery = `query GetHomePage {
  page(id: "home", idType: URI) {
   seo {
      title
      fullHead
    }
    homePage {
      mainTitle
      subTitle
      
      short
      provideImage{
        node{
          sourceUrl
          mediaDetails{
            width
            height
          }
        }
      }
      mainTitleProvider
      providerFields{
        link
        provideContent
        title
        cta
      }
    }
  }
}`;

let Homepageres = await fetchAPI(Homequery);
---

<BaseLayout
  title={Homepageres.page.seo.title}
  fullHead={Homepageres.page.seo.fullHead}
>
  <link
    rel="preload"
    href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
    as="style"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
    />
  </noscript>

  <!-- HERO -->
  <section class="hero-section">
    <div class="three-slider">
      <Homeslider />
    </div>
  </section>

  <!-- PLANS -->
  <section class="health-plans">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">
          {Homepageres.page.homePage.mainTitle}
        </span>
        <h2 class="fs-37">
          {Homepageres.page.homePage.subTitle}
        </h2>
        <p>{Homepageres.page.homePage.short}</p>
      </div>

      <Plans />
    </div>
  </section>

  <!-- PROVIDER -->
 <section class="request-apointment">
  <div class="container">
    <div class="bottom-data">
      <div class="bottom-img">

        <Image
          src={Homepageres.page.homePage.provideImage.node.sourceUrl}
          alt={Homepageres.page.homePage.mainTitleProvider}
          width={600}
          height={368}
          format="avif"
          quality={80}
          loading="lazy"
          decoding="async"
          sizes="(max-width: 768px) 100vw, 50vw"
        />

      </div>

      <div class="bottom-content">
        <span class="section-tag">
          {Homepageres.page.homePage.mainTitleProvider}
        </span>

        <div class="datagridsss">
          {
            Homepageres.page.homePage.providerFields.map((item) => (
              <div class="main-dataa">
                <h3 class="fs-30">{item.title}</h3>
                <p>{item.provideContent}</p>
                <a href={item.link} class="c-btn">
                  <span>{item.cta}</span>
                </a>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

  <!-- PAGE SPECIFIC SCRIPTS -->
<script>
  let swiperLoaded = false;

  function loadSwiper(callback) {
    if (swiperLoaded) {
      callback && callback();
      return;
    }

    const script = document.createElement("script");
    script.src = "/assets/js/swiper-bundle.min.js";
    script.async = true;

    script.onload = () => {
      swiperLoaded = true;
      callback && callback();
    };

    document.body.appendChild(script);
  }

  function initSwipers() {
    // First slider
    const mainSlider = document.querySelector(".mySwipercardsliders");

    if (mainSlider && !mainSlider.classList.contains("swiper-initialized")) {
      new Swiper(mainSlider, {
        slidesPerView: 3,
        spaceBetween: 30,
        speed: 1000,
        autoplay: {
          delay: 5000,
          disableOnInteraction: false,
        },
        pagination: {
          el: ".swiper-pagination",
          clickable: true,
        },
        breakpoints: {
          0: { slidesPerView: 1 },
          576: { slidesPerView: 2 },
          992: { slidesPerView: 3 },
        },
      });
    }

    // Second sliders
    document.querySelectorAll(".slider-js").forEach((container) => {
      const swiperEl = container.querySelector(".mySwiperthree");

      if (!swiperEl || swiperEl.classList.contains("swiper-initialized")) return;

      const swiper = new Swiper(swiperEl, {
        speed: 1500,
        loop: true,
        autoplay: {
          delay: 1000,
          disableOnInteraction: false,
        },
      });

      swiper.autoplay.stop();

      container.addEventListener("mouseenter", () => swiper.autoplay.start());
      container.addEventListener("mouseleave", () => swiper.autoplay.stop());
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    const sliderSection = document.querySelector(".mySwipercardsliders");

    if (!sliderSection) return;

    // 🚀 1. Preload BEFORE visible (no delay UX)
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            loadSwiper(initSwipers);
            observer.disconnect();
          }
        });
      },
      {
        rootMargin: "500px", // 👈 key fix (fast load before visible)
      }
    );

    observer.observe(sliderSection);

    // 🚀 2. Fallback (agar user scroll na kare)
    window.addEventListener("load", () => {
      setTimeout(() => {
        loadSwiper(initSwipers);
      }, 2000);
    });

    // 🚀 3. Instant load on interaction (UX boost)
    sliderSection.addEventListener("mouseenter", () => {
      loadSwiper(initSwipers);
    });
  });
</script>
</BaseLayout>

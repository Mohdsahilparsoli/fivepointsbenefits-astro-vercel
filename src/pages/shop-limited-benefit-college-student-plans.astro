---
import BaseLayout from "../layouts/BaseLayout.astro";

import { fetchAPI } from "../lib/wordpress";

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=120, stale-while-revalidate=30",
);

const Homequery = `query GetPage {
  page(id: "member", idType: URI) {
    title
    content
    slug
    uri
     seo {
      title
      fullHead
    }
    featuredImage {
      node {
        sourceUrl
        mediaDetails {
          
          height
          width
        }
      }
    }
    memberPortal {
      memberPortalInfo
      findeCarePortal
      optumrx {
        link
        subTitle
        title
        optumrxProfile {
          node {
            sourceUrl
            mediaDetails {
              file
              filePath
              height
              width
            }
          }
        }
      }
      formFinderPortal
    }
  }
}`;

let member = await fetchAPI(Homequery);

const items = member.page.memberPortal.optumrx;

---
import BaseLayout from "../layouts/BaseLayout.astro";

import { fetchAPI } from "../lib/wordpress";

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=120, stale-while-revalidate=30'
);

const Homequery = `query GetPage {
  page(id: "form-finder", idType: URI) {
    title
    content
    slug
    uri
     seo {
      title
      fullHead
    }
featuredImage {
  node {
    sourceUrl
    mediaDetails {
      file
      filePath
      height
      width
    }
  }
}
    formFinder {
      formFinderInfo
    }
  }
}`;

let formfinder = await fetchAPI(Homequery);
---

 <BaseLayout title={formfinder.page.seo.title} fullHead={formfinder.page.seo.fullHead}>
  <section class="member-sec provider data-flow data-text">
    <div class="container">
      <div class="row gy-4 align-items-center">
        <div class="col-lg-7" set:html={formfinder.page.content} />
        <div class="col-lg-5">
          <div class="image-members">
            <img
              src={formfinder.page.featuredImage.node.sourceUrl}
              alt={formfinder.page.title}
              width={formfinder.page.featuredImage.node.width}
              height={formfinder.page.featuredImage.node.height}
            />
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="memberportal-secc bg-white flow">
    <div set:html={formfinder.page.formFinder.formFinderInfo} />
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";

import { fetchAPI } from "../lib/wordpress";

const Howtoenrol = `
query GetPage {
  page(id: "how-to-enrol-individuals-and-families", idType: URI) {
    title
    content
    slug
    uri
     seo {
      title
      fullHead
    }
       familiesImage { 
      familyImg {
        # Inside the repeater, check if your image needs a 'node'
        familyImage {
          node {
            sourceUrl
            altText
          }
        }
      }
    }
    featuredImage {
      node {
        sourceUrl
        mediaDetails {
          file
          filePath
          height
          width
        }
      }
    }
  }
}
`;

let familyenrol = await fetchAPI(Howtoenrol);
---

   <BaseLayout title={familyenrol.page.seo.title} fullHead={familyenrol.page.seo.fullHead}>
  <section class="employermain-sec section-padding pb-0">
    <div class="container">
      <div class="employer-holderss">
        <div class="imageempoyergroups">
          <img
            src={familyenrol.page.featuredImage.node.sourceUrl}
            width={familyenrol.page.featuredImage.node.mediaDetails.width}
            height={familyenrol.page.featuredImage.node.mediaDetails.height}
            alt={familyenrol.page.title}
          />
        </div>
        <div set:html={familyenrol.page.content} />
      </div>
      <div class="employer-holderss">
        <div class="logos">
          {
            familyenrol.page.familiesImage.familyImg.map((item) => (
              <div class="main-img">
                <img
                  src={item.familyImage.node.sourceUrl}
                  alt={item.familyImage.node.altText || "family image"}
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchAPI } from "../lib/wordpress";

const Homequery = `
query GetPage {
  page(id: "employer-group", idType: URI) {
    title
    content
    slug
    uri
     seo {
      title
      fullHead
    }
    employerPlan {
      employerPlan {
        backgroundColor
        sbcPlan
        sobPlan
        subTitle
        title
      }
      fivePointLetter
      employerGalarry {
        gallaryProfile {
          node {
            sourceUrl
            mediaDetails {
              height
              width
            }
          }
        }
      }
    }
  }
}
`;

let plan = await fetchAPI(Homequery);
---

 <BaseLayout title={plan.page.seo.title} fullHead={plan.page.seo.fullHead}>

  <section class="employermain-sec section-padding shoupourplans-sec">

    <!-- GALLERY -->
    <div class="imageempoyergroups">
      {
        plan?.page?.employerPlan?.employerGalarry?.map((item, index) => {
          const img = item?.gallaryProfile?.node;

          return (
            <img
              key={index}
              src={img?.sourceUrl}
              alt={`gallery-${index}`}
            />
          );
        })
      }
    </div>

    <div class="container">

      <!-- PAGE CONTENT -->
      <div set:html={plan.page.content} />

      <!-- PLANS -->
      <div class="plans-gridholders">
        <div class="row palnsrows justify-content-center">

          {
            plan?.page?.employerPlan?.employerPlan?.map((item) => (
              <div class="col-md-6 col-lg-4">
                <div class="holders-planssss">

                  <h4 class="fs-20">COMPLETE CARE PLAN</h4>

                  <div class="image-holderssplanss">
                    <div
                      class="allchild-holders"
                      style={{ background: item.backgroundColor }}
                    >
                      <div class="image-dtaaplans">
                        <img
                          src="/assets/img/logoplans.png"
                          alt={item.title}
                          loading="lazy"
                        />
                      </div>

                      <div class="allplans-detailsss">
                        <h5 class="plansnamee">{item.title}</h5>
                        <p>{item.subTitle}</p>
                      </div>
                    </div>
                  </div>

                  <!-- BUTTONS -->
                  <div class="button-plansss">
                    <div class="grid-butttonsplans">

                      <div class="universal-newbutton">
                        <a
                          href={item.sobPlan}
                          target="_blank"
                          class="newbutton-universal"
                          title={`${item.title} SOB`}
                        >
                          COMPLETE CARE Plan SOB
                        </a>
                      </div>

                      <div class="universal-newbutton">
                        <a
                          href={item.sbcPlan}
                          target="_blank"
                          class="newbutton-universal"
                          title={`${item.title} SBC`}
                        >
                          COMPLETE CARE Plan SBC
                        </a>
                      </div>

                    </div>
                  </div>

                </div>
              </div>
            ))
          }

        </div>

        <!-- EXTRA CONTENT -->
        <div set:html={plan?.page?.employerPlan?.fivePointLetter} />

      </div>

    </div>
  </section>

</BaseLayout>
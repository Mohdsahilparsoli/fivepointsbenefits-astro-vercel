---
import { fetchAPI } from "../lib/wordpress";
import { Image } from "astro:assets";

const homeslider = `
query GetAllPlans {
  homeSliders(first: 10, where: { orderby: { field: DATE, order: DESC } }) {
    nodes {
      content
      title
      homeSliderImage {
        homeSliderImg {
          sliderImg {
            node {
              sourceUrl
              mediaDetails {
                width
                height
                sizes {
                  name
                  sourceUrl
                  width
                  height
                }
              }
            }
          }
        }
      }
    }
  }
}`;
const Slider = await fetchAPI(homeslider);
---

{
  Slider.homeSliders.nodes.map((curent, index) => {
    return (
      <div class="slider-js">
        <div class="swiper mySwiperthree">
          <div class="swiper-wrapper">

            {curent.homeSliderImage.homeSliderImg.map((curentval, i) => {
              const img = curentval.sliderImg.node;

              // 👇 responsive sizes (WordPress se)
              const small = img.mediaDetails.sizes?.find(s => s.name === "medium")?.sourceUrl || img.sourceUrl;
              const large = img.mediaDetails.sizes?.find(s => s.name === "large")?.sourceUrl || img.sourceUrl;

              const isLCP = index === 0 && i === 0;

              return (
                <div class="swiper-slide">
                  <div class="main-slider-img">

                    <img
                      src={large}
                      srcset={`${small} 768w, ${large} 1200w`}
                      sizes="(max-width: 768px) 100vw, 1200px"
                      alt={curent.title}
                      width={img.mediaDetails.width}
                      height={img.mediaDetails.height}
                      
                      loading={isLCP ? "eager" : "lazy"}
                      fetchpriority={isLCP ? "high" : "auto"}
                      decoding="async"
                      style="width:100%; height:auto;"
                    />

                  </div>
                </div>
              );
            })}

          </div>
        </div>

        <div class="top-section-data">
          <div set:html={curent.content} />
        </div>
      </div>
    );
  })
}

<style>
  .main-slider-img img{
    height: 100% !important;
  }
</style>
---
import { fetchAPI } from "../lib/wordpress";

const plans = `query GetAllPlans {
  ourPlans {
    nodes {
      title
      slug
      excerpt
      featuredImage {
        node {
          sourceUrl
          mediaDetails {
            width
            height
            sizes {
              name
              sourceUrl
              width
            }
          }
        }
      }
    }
  }
}`;

const res = await fetchAPI(plans);

const plansData = (res.ourPlans.nodes || []).sort((a, b) => {
  const order = {
    "employer group plans": 1,
    "college student plans": 2,
    "individual & family plans": 3
  };

  return (order[a.title.toLowerCase()] || 99) - (order[b.title.toLowerCase()] || 99);
});
---

<div class="plans-grid">
  <div class="swiper mySwipercardsliders">
    <div class="swiper-wrapper">

      {
        plansData.map((plan, index) => {
          const img = plan.featuredImage?.node;

          const small = img?.mediaDetails?.sizes?.find(s => s.name === "medium")?.sourceUrl || img?.sourceUrl;
          const large = img?.mediaDetails?.sizes?.find(s => s.name === "large")?.sourceUrl || img?.sourceUrl;

          const isFirst = index === 0;

          return (
            <div class="swiper-slide">
              <div class="plan-card">

                <div class="plan-img">
                  <a href={`/${plan.slug}`}>

                    {img && (
                      <img
                        src={large}
                        srcset={`
                          ${small} 400w,
                          ${large} 800w,
                          ${img.sourceUrl} 1200w
                        `}
                        sizes="(max-width: 768px) 100vw, 33vw"

                        alt={plan.title}
                        width={img.mediaDetails?.width || 400}
                        height={img.mediaDetails?.height || 300}

                        loading={isFirst ? "eager" : "lazy"}
                        fetchpriority={isFirst ? "high" : "auto"}
                        decoding="async"

                        style="width:100%; height:auto;"
                      />
                    )}

                  </a>
                </div>

                <div class="plan-data" style="min-height: 260px;">
                  <div>
                    <h3 class="fs-25">
                      <a href={`/${plan.slug}`}>{plan.title}</a>
                    </h3>

                    <div set:html={plan.excerpt} />
                  </div>

                  <div class="button-card">
                    <a href={`/${plan.slug}`} class="c-btn">
                      Explore Plans
                    </a>
                  </div>
                </div>

              </div>
            </div>
          );
        })
      }

    </div>

    <div class="custom-page">
      <div class="swiper-pagination"></div>
    </div>
  </div>
</div>
---
import { fetchAPI } from "../lib/wordpress";

/* ================================
   GET FULL MENU
================================ */
const GET_FULL_MENU = `
query GetFullMenu {
  menu(id: "mainmenu", idType: SLUG) {
    menuItems(first: 200) {
      nodes {
        id
        label
        uri
        parentId
      }
    }
  }
  siteLogo {
    sourceUrl
    altText
    mediaDetails {
      width
      height
      sizes {
        name
        sourceUrl
        width
      }
    }
  }
}
`;

const data = await fetchAPI(GET_FULL_MENU);

const allMenuItems = data?.menu?.menuItems?.nodes || [];

/* ================================
   BUILD TREE
================================ */
function buildMenuTree(items, parentId = null) {
  return items
    .filter((item) => item.parentId === parentId)
    .map((item) => ({
      ...item,
      children: buildMenuTree(items, item.id),
    }));
}

const menuTree = buildMenuTree(allMenuItems);
const siteLogo = data?.siteLogo || null;

/* ================================
   LOGO SIZES
================================ */
const smallLogo =
  siteLogo?.mediaDetails?.sizes?.find(s => s.name === "medium")?.sourceUrl ||
  siteLogo?.sourceUrl;

const largeLogo = siteLogo?.sourceUrl;
---

{/* 🔥 PRELOAD LOGO (LCP BOOST) */}
{largeLogo && (
  <link rel="preload" as="image" href={largeLogo} />
)}

<header class="custom-header">

  {/* TOP BAR */}
  <div class="sticky">
    <div class="container">

      <div class="right-value">
        <ul>
          <li class="lang">
            <select id="languageSelect">
              <option value="">Choose Your Language</option>
              <option value="en">English</option>
              <option value="hi">Hindi</option>
              <option value="bn">Bengali</option>
              <option value="ta">Tamil</option>
              <option value="te">Telugu</option>
            </select>
          </li>
        </ul>
      </div>

      <div class="right-value">
        <ul>
          <li><a href="/portal">Member Login</a></li>
          <li><a href="/portal">Provider Login</a></li>
        </ul>
      </div>

    </div>
  </div>

  {/* MAIN HEADER */}
  <div class="bottom-header">
    <div class="container">
      <div class="grid-bottom">

        <div class="mobile-grid">

          {/* 🔥 LOGO */}
          <div class="main-logo">
            <a href="/">
              {siteLogo && (
                <img
                  src={largeLogo}
                  srcset={`${smallLogo} 200w, ${largeLogo} 400w`}
                  sizes="(max-width: 768px) 150px, 200px"

                  alt={siteLogo.altText || "Logo"}
                  width={siteLogo.mediaDetails?.width || 195}
                  height={siteLogo.mediaDetails?.height || 88}

                  loading="eager"
                  fetchpriority="high"
                  decoding="async"

                  style="width:auto; height:auto;"
                />
              )}
            </a>
          </div>

          {/* MENU ICON */}
          <div class="main-menu-data">
            <div class="menu-icon">
              <img
                src="/assets/img/menu-btn.png"
                alt="menu"
                width="40"
                height="40"
                loading="lazy"
              />
            </div>
          </div>

        </div>

        {/* NAV MENU */}
        <div class="all-here">
          <ul class="bottom-navlists zindex">
            {
              menuTree.map((item) => (
                <li class={item.children.length > 0 ? "menu-item-has-children" : ""}>
                  <a href={item.uri}>{item.label}</a>

                  {item.children.length > 0 && (
                    <ul class="sub-menu">
                      {item.children.map((child) => (
                        <li class={child.children.length > 0 ? "menu-item-has-children" : ""}>
                          <a href={child.uri}>{child.label}</a>

                          {child.children.length > 0 && (
                            <ul class="sub-menu">
                              {child.children.map((grandChild) => (
                                <li>
                                  <a href={grandChild.uri}>{grandChild.label}</a>
                                </li>
                              ))}
                            </ul>
                          )}

                        </li>
                      ))}
                    </ul>
                  )}

                </li>
              ))
            }
          </ul>
        </div>

      </div>
    </div>
  </div>
</header>

<div class="mt"></div>
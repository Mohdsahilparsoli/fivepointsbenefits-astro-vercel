---
// CSS
// import "bootstrap/dist/css/bootstrap.min.css";
import "../styles/bootstrap.min.css"
import "../styles/custom.css";
import "../styles/h.css";
import "../styles/responsive.css";

import type { ImageMetadata } from "astro";
import FallbackImage from "../assets/blog-placeholder-1.jpg";
import { SITE_TITLE } from "../consts";

interface Props {
  title: string;
  fullHeaddata?: string;
  image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, fullHeaddata, image = FallbackImage } = Astro.props;
---

<!-- ✅ BASIC META -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<!-- ✅ TITLE -->
<title>{title}</title>

<!-- ✅ CANONICAL -->
<link rel="canonical" href={canonicalURL} />

<!-- ✅ YOAST SEO HEAD (MAIN POWER) -->
{fullHeaddata && (
  <Fragment set:html={fullHeaddata} />
)}

<!-- ✅ FAVICON -->
<link rel="icon" href="/favicon.jpg" />

<!-- ✅ RSS -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE_TITLE}
  href={new URL("rss.xml", Astro.site)}
/>

<!-- ✅ GOOGLE FONTS -->
<!-- Preconnect -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<!-- Preload font CSS -->
<link 
  rel="preload" 
  as="style" 
  href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,600&display=swap"
  onload="this.onload=null;this.rel='stylesheet'"
>

<noscript>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,600&display=swap" rel="stylesheet">
</noscript>




---
// ✅ CSS (Astro handle karega – SAFE & OPTIMIZED)
import "../styles/main.css";

import type { ImageMetadata } from "astro";
import FallbackImage from "../assets/blog-placeholder-1.jpg";
import { SITE_TITLE } from "../consts";

interface Props {
  title: string;
  fullHeaddata?: string;
  image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, fullHeaddata, image = FallbackImage } = Astro.props;
---


<!-- ✅ BASIC META -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<!-- ✅ TITLE -->
<title>{title}</title>

<!-- ✅ CANONICAL -->
<link rel="canonical" href={canonicalURL} />

<!-- ✅ YOAST SEO -->
{fullHeaddata && <Fragment set:html={fullHeaddata} />}

<!-- ✅ FAVICON -->
<link rel="icon" href="/favicon.jpg" />

<!-- ✅ RSS -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE_TITLE}
  href={new URL("rss.xml", Astro.site)}
/>


<!-- 🔥 FONT OPTIMIZATION (NON-BLOCKING) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link
  href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800&display=swap"
  rel="preload"
  as="style"
  onload="this.rel='stylesheet'"
/>


<noscript>
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800&display=swap" rel="stylesheet">
</noscript>


{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/about-us/?$",
			"dest": "_render"
		},
		{
			"src": "^/about-us(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/send-otp/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/verify-otp/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact-details/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact-us/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact-us copy/?$",
			"dest": "_render"
		},
		{
			"src": "^/employer-group-plans/?$",
			"dest": "_render"
		},
		{
			"src": "^/employer-group-rbp-plans/?$",
			"dest": "_render"
		},
		{
			"src": "^/find-provider/?$",
			"dest": "_render"
		},
		{
			"src": "^/form-finder/?$",
			"dest": "_render"
		},
		{
			"src": "^/how-to-enrol-individuals-families/?$",
			"dest": "_render"
		},
		{
			"src": "^/how-to-enroll-employer-groups/?$",
			"dest": "_render"
		},
		{
			"src": "^/index copy/?$",
			"dest": "_render"
		},
		{
			"src": "^/individual-family-rbp-plans/?$",
			"dest": "_render"
		},
		{
			"src": "^/individuals-families-plans/?$",
			"dest": "_render"
		},
		{
			"src": "^/members/?$",
			"dest": "_render"
		},
		{
			"src": "^/mission-statement/?$",
			"dest": "_render"
		},
		{
			"src": "^/optum-rx/?$",
			"dest": "_render"
		},
		{
			"src": "^/portal/?$",
			"dest": "_render"
		},
		{
			"src": "^/providers/?$",
			"dest": "_render"
		},
		{
			"src": "^/README/?$",
			"dest": "_render"
		},
		{
			"src": "^/rss\\.xml$",
			"dest": "_render"
		},
		{
			"src": "^/teladoc/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}